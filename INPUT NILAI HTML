<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Input Nilai - SiNilai</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="index.html">📄 SiNilai</a>
            <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="index.html">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link active" href="input-nilai.html">Input Nilai</a></li>
                    <li class="nav-item"><a class="nav-link" href="rekap.html">Rekap Semester</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row g-4">

            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white">
                        <strong>➕ Tambah Nilai Mata Kuliah</strong>
                    </div>
                    <div class="card-body">

                        <div id="areaAlert" class="d-none mb-3"></div>

                        <form id="formInputNilai">

                            <div class="mb-3">
                                <label for="inputNamaMk" class="form-label">
                                    Nama Mata Kuliah <span class="text-danger">*</span>
                                </label>
                                <input 
                                    type="text" 
                                    class="form-control" 
                                    id="inputNamaMk" 
                                    placeholder="Contoh: Pemrograman Web"
                                >
                                <div class="invalid-feedback">Nama mata kuliah wajib diisi.</div>
                            </div>

                            <div class="mb-3">
                                <label for="inputSks" class="form-label">
                                    SKS <span class="text-danger">*</span>
                                </label>
                                <select class="form-select" id="inputSks">
                                    <option value="">-- Pilih SKS --</option>
                                    <option value="1">1 SKS</option>
                                    <option value="2">2 SKS</option>
                                    <option value="3">3 SKS</option>
                                    <option value="4">4 SKS</option>
                                </select>
                                <div class="invalid-feedback">SKS wajib dipilih.</div>
                            </div>

                            <div class="mb-3">
                                <label for="inputNilaiAngka" class="form-label">
                                    Nilai Angka (0-100) <span class="text-danger">*</span>
                                </label>
                                <input
                                    type="number"
                                    class="form-control"
                                    id="inputNilaiAngka"
                                    placeholder="Contoh: 85"
                                    min="0"
                                    max="100"
                                >
                                <div class="invalid-feedback">Nilai harus antara 0 sampai 100.</div>
                            </div>

                            <div class="mb-3">
                                <label for="inputSemester" class="form-label">
                                    Semester <span class="text-danger">*</span>
                                </label>
                                <select class="form-select" id="inputSemester">
                                    <option value="">-- Pilih Semester --</option>
                                    <option value="1">Semester 1</option>
                                    <option value="2">Semester 2</option>
                                    <option value="3">Semester 3</option>
                                    <option value="4">Semester 4</option>
                                </select>
                                <div class="invalid-feedback">Semester wajib dipilih.</div>
                            </div>

                            <div id="previewGrade" class="alert alert-light border d-none mb-3">
                                </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-dark">
                                    💾 Simpan Nilai
                                </button>
                                <button type="reset" class="btn btn-outline-secondary btn-sm">
                                    Reset Form
                                </button>
                            </div>

                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <strong>📊 Data Nilai Tersimpan</strong>
                        <div>
                            <span class="badge bg-dark me-2" id="badgeJumlahData">0 MK</span>
                            <span class="me-1 text-muted small">IPK:</span>
                            <span class="badge bg-secondary" id="badgeIpk">-</span>
                        </div>
                    </div>

                    <div class="card-body p-0">

                        <div class="p-3 border-bottom bg-light">
                            <input 
                                type="text" 
                                id="inputCariMk" 
                                class="form-control form-control-sm" 
                                placeholder="🔍 Cari nama mata kuliah di sini..."
                            >
                        </div>

                        <div id="pesanTabelKosong" class="text-center py-5">
                            <p class="text-muted">Belum ada nilai. Tambahkan melalui form di sebelah kiri.</p>
                        </div>

                        <div id="areaTabelInput" class="d-none">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-dark">
                                        <tr>
                                            <th>No</th>
                                            <th>Mata Kuliah</th>
                                            <th class="text-center">SKS</th>
                                            <th class="text-center">Nilai</th>
                                            <th class="text-center">Grade</th>
                                            <th class="text-center">Sem</th>
                                            <th class="text-center">Aksi</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tabelInputNilai">
                                        </tbody>
                                </table>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="text-end mt-2" id="areaTombolHapusSemua">
                    <button class="btn btn-outline-danger btn-sm d-none" id="tombolHapusSemua">
                        🗑️ Hapus Semua Data
                    </button>
                </div>

            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="script.js"></script>

</body>
</html>
